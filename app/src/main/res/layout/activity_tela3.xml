<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tela3"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ============================================================
             Ícone de info (Material Design)
        ============================================================= -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:src="@android:drawable/ic_dialog_info"
            android:contentDescription="@string/cd_icone_sobre" />

        <!-- Nome do trabalho -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center"
            android:text="@string/sobre_app_nome"
            android:textColor="#E3F2FD"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Disciplina -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center"
            android:text="@string/sobre_disciplina"
            android:textColor="#90CAF9"
            android:textSize="13sp" />

        <!-- Faixa azul decorativa -->
        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:background="#1E88E5" />

        <!-- ============================================================
             Card: Curso
        ============================================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#1A2A3A"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/label_curso"
                android:textColor="#1E88E5"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.12" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/sobre_curso"
                android:textColor="#E3F2FD"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/label_semestre"
                android:textColor="#1E88E5"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.12" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sobre_semestre"
                android:textColor="#E3F2FD"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ============================================================
             Card: Integrantes
        ============================================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:background="#1A2A3A"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/sobre_titulo_integrantes"
                android:textColor="#1E88E5"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.12" />

            <!-- Integrante 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="#1E88E5"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sobre_nome1"
                        android:textColor="#E3F2FD"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sobre_ra1"
                        android:textColor="#90CAF9"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divisor -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#2A3A4A" android:layout_marginBottom="12dp"/>

            <!-- Integrante 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="#1E88E5"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sobre_nome2"
                        android:textColor="#E3F2FD"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sobre_ra2"
                        android:textColor="#90CAF9"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divisor -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#2A3A4A" android:layout_marginBottom="12dp"/>

            <!-- Integrante 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="#1E88E5"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sobre_nome3"
                        android:textColor="#E3F2FD"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sobre_ra3"
                        android:textColor="#90CAF9"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>



    </LinearLayout>
</ScrollView>