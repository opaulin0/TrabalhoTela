<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:background="#F5F5F5">

    <!-- ================================================================
         Card central com os dados cadastrados
    ================================================================= -->
    <LinearLayout
        android:id="@+id/ll_dados"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginTop="24dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Cabeçalho do card -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/titulo_dados_cadastrados"
            android:textColor="#1565C0"
            android:textSize="17sp"
            android:textStyle="bold" />

        <!-- Nome -->
        <TextView
            android:id="@+id/tv_resultado_nome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="#212121"
            android:textSize="16sp" />

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="#E0E0E0" />

        <!-- Idade -->
        <TextView
            android:id="@+id/tv_resultado_idade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="#212121"
            android:textSize="16sp" />

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="#E0E0E0" />

        <!-- Endereço -->
        <TextView
            android:id="@+id/tv_resultado_endereco"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#212121"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- ================================================================
         Rodapé: pergunta + dois botões lado a lado
    ================================================================= -->
    <LinearLayout
        android:id="@+id/ll_confirmacao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="@string/pergunta_corretos"
            android:textColor="#424242"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Botões lado a lado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_sim"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#2E7D32"
                android:text="@string/btn_sim"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_nao"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:backgroundTint="#C62828"
                android:text="@string/btn_nao"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>